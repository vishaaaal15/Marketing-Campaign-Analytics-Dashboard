      <aliases enabled='yes' />
      <column caption='Total Spendings' datatype='integer' name='[Calculation_439945392172351488]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[MntWines] + [MntFruits] + [MntMeatProducts] +&#13;&#10;[MntFishProducts] + [MntSweetProducts] + [MntGoldProds]' />
      </column>
      <column caption='Age' datatype='integer' name='[Calculation_439945392172666881]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='YEAR(TODAY()) - [Year_Birth]' />
      </column>
      <column caption='Customer Segment' datatype='string' name='[Calculation_439945392172752898]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Income] &gt; 70000 THEN &quot;High Income&quot;&#13;&#10;ELSEIF [Income] &gt; 40000 THEN &quot;Middle Income&quot;&#13;&#10;ELSE &quot;Low Income&quot;&#13;&#10;END' />
      </column>
      <column caption='Placeholder' datatype='integer' name='[Calculation_439945392181714947]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MIN(1)' />
      </column>
